# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (for production - PostgreSQL on Azure)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=mocon_db
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=your-azure-db.postgres.database.azure.com
DB_PORT=5432

# OpenAI API (for AI content generation)
OPENAI_API_KEY=your-openai-api-key-here

# Stripe
STRIPE_PUBLIC_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_MARKETPLACE_WEBHOOK_SECRET=whsec_...
MARKETPLACE_FEE_PERCENT=10

# Hotel Affiliate — Expedia Travel Creator
# Your tracking code = the part after the dot in your generated link
# e.g. https://expedia.com/affiliates/expedia-home.Md9OTSL → tracking code is Md9OTSL
AFFILIATE_EXPEDIA_TRACKING=vMuLnPe
# Booking.com → https://www.booking.com/affiliate-program.html
AFFILIATE_BOOKING_COM_AID=

# Social OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# Google Analytics
GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X

# Azure Storage (for media files in production)
AZURE_STORAGE_ACCOUNT_NAME=your_storage_account
AZURE_STORAGE_ACCOUNT_KEY=your_storage_key
AZURE_STORAGE_CONTAINER=media
